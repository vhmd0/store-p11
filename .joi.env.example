# joi configuration
# Copy this file to .joi.env and customize as needed
# Precedence: CLI flags > JOI_* env vars > .joi.env > defaults

# Auto-answer prompts (y/n)
SEED_DATA=y
CREATE_ADMIN=n

# Default server port
PORT=8000

# Python interpreter path (auto-detected if not set)
# PYTHON=.venv/bin/python
